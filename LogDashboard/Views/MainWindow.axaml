<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:LogDashboard.ViewModels"
        xmlns:converters="using:LogDashboard.Converters"
        xmlns:models="using:LogDashboard.Models"
        mc:Ignorable="d"
        d:DesignWidth="1600"
        d:DesignHeight="900"
        x:Class="LogDashboard.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Log Dashboard"
        Background="{DynamicResource SystemChromeMediumLowColor}"
        MinWidth="900"
        MinHeight="600">

    <Window.Resources>
        <converters:LogLevelToBrushConverter x:Key="LogLevelToBrushConverter" />
        <converters:LogLevelToBackgroundConverter x:Key="LogLevelToBackgroundConverter" />
    </Window.Resources>

    <Window.Styles>

        <!-- ── Sidebar stat row ── -->
        <Style Selector="Button.StatRow">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="6,5" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.StatRow:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SystemListLowColor}" />
        </Style>
        <Style Selector="Button.StatRow.Active /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SystemListMediumColor}" />
        </Style>

        <!-- ── Time chip ── -->
        <Style Selector="Button.TimeChip">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="7,3" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.TimeChip:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SystemListLowColor}" />
        </Style>
        <Style Selector="Button.TimeChip.Active /template/ ContentPresenter">
            <Setter Property="Background" Value="#1D4ED8" />
        </Style>
        <Style Selector="Button.TimeChip.Active">
            <Setter Property="BorderBrush" Value="#1D4ED8" />
            <Setter Property="Foreground" Value="#BFDBFE" />
        </Style>

        <!-- ── Icon button in toolbar ── -->
        <Style Selector="Button.IconBtn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style Selector="Button.IconBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SystemListLowColor}" />
        </Style>
        <Style Selector="Button.IconBtn.Watching">
            <Setter Property="BorderBrush" Value="#22C55E" />
            <Setter Property="Foreground" Value="#22C55E" />
        </Style>

        <!-- ── Section label ── -->
        <Style Selector="TextBlock.SideLabel">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Opacity" Value="0.45" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="LetterSpacing" Value="1.5" />
        </Style>

        <!-- ── Level badge ── -->
        <Style Selector="Border.LevelBadge">
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Padding" Value="5,1" />
        </Style>

        <!-- ── DataGrid row left-border accent via tag ── -->
        <Style Selector="DataGridRow">
            <Setter Property="FontFamily" Value="Cascadia Code,Consolas,Monospace" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <!-- ── Detail section ── -->
        <Style Selector="TextBlock.DetailKey">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Opacity" Value="0.45" />
            <Setter Property="Margin" Value="0,0,0,3" />
            <Setter Property="LetterSpacing" Value="1.2" />
        </Style>

        <Style Selector="TextBlock.DetailVal">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style Selector="TextBlock.Mono">
            <Setter Property="FontFamily" Value="Cascadia Code,Consolas,Monospace" />
            <Setter Property="FontSize" Value="11" />
        </Style>

    </Window.Styles>

    <!-- ══════════════════════════════════════════════
         ROOT: Titlebar + Body
    ══════════════════════════════════════════════ -->
    <Grid RowDefinitions="Auto,*">

        <!-- ── Titlebar ── -->
        <Border Grid.Row="0"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                Padding="14,0">
            <Grid ColumnDefinitions="*,Auto"
                  Height="44">

                <StackPanel Orientation="Horizontal"
                            Spacing="12"
                            VerticalAlignment="Center">

                    <TextBlock Text="LOG DASHBOARD"
                               FontSize="12"
                               FontWeight="SemiBold"
                               LetterSpacing="2"
                               Opacity="0.85" />

                    <!-- Watching indicator -->
                    <StackPanel Orientation="Horizontal"
                                Spacing="5"
                                VerticalAlignment="Center"
                                IsVisible="{Binding IsWatching}">
                        <Ellipse Width="6"
                                 Height="6"
                                 Fill="#22C55E">
                            <!-- pulse via opacity animation -->
                        </Ellipse>
                        <TextBlock Text="watching"
                                   FontSize="11"
                                   Foreground="#22C55E" />
                    </StackPanel>
                </StackPanel>

                <!-- Toolbar buttons -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="6"
                            VerticalAlignment="Center">

                    <!-- Folder path chip -->
                    <Border Background="{DynamicResource SystemListLowColor}"
                            CornerRadius="5"
                            Padding="10,4"
                            MaxWidth="320">
                        <TextBlock Text="{Binding CurrentFolder}"
                                   FontSize="11"
                                   FontFamily="Cascadia Code,Consolas,Monospace"
                                   Opacity="0.6"
                                   TextTrimming="CharacterEllipsis" />
                    </Border>

                    <Button Classes="IconBtn"
                            Command="{Binding ToggleWatcherCommand}"
                            ToolTip.Tip="{Binding WatcherButtonTooltip}"
                            Classes.Watching="{Binding IsWatching}"
                            Content="{Binding WatcherButtonIcon}" />

                    <Button Classes="IconBtn"
                            Command="{Binding RefreshCommand}"
                            ToolTip.Tip="重新整理"
                            Content="↺" />

                    <Button Classes="IconBtn"
                            Command="{Binding SelectFolderCommand}"
                            ToolTip.Tip="選擇資料夾"
                            Content="📁" />

                    <Button Classes="IconBtn"
                            Command="{Binding ToggleThemeCommand}"
                            ToolTip.Tip="切換主題"
                            Content="🌓" />

                    <ComboBox ItemsSource="{Binding RefreshIntervals}"
                              SelectedItem="{Binding SelectedRefreshInterval}"
                              Width="80"
                              FontSize="11"
                              VerticalAlignment="Center" />

                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════
             BODY: Sidebar | Main | Detail
        ══════════════════════════════════════════════ -->
        <Grid Grid.Row="1"
              ColumnDefinitions="220,*,Auto,360">

            <!-- ─────────────────────────────────────────
                 LEFT SIDEBAR
            ───────────────────────────────────────── -->
            <Border Grid.Column="0"
                    BorderThickness="0,0,1,0"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">

                <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>

                        <!-- Overview block -->
                        <Border Padding="14,14,14,12">
                        <StackPanel Spacing="4">
                            <TextBlock Classes="SideLabel"
                                       Text="OVERVIEW" />
                            <StackPanel Orientation="Horizontal"
                                        Spacing="6"
                                        VerticalAlignment="Bottom">
                                <TextBlock Text="{Binding TotalCount}"
                                           FontSize="28"
                                           FontWeight="Medium"
                                           LineHeight="28" />
                                <TextBlock Text="total logs"
                                           FontSize="11"
                                           Opacity="0.45"
                                           VerticalAlignment="Bottom"
                                           Margin="0,0,0,3" />
                            </StackPanel>
                        </StackPanel>
                        </Border>

                        <Separator Margin="0" />

                        <!-- Level filter -->
                        <Border Padding="14,12,14,10">
                        <StackPanel Spacing="2">
                            <TextBlock Classes="SideLabel"
                                       Text="LEVEL" />

                            <Button Classes="StatRow"
                                    Command="{Binding SetLevelFilterCommand}"
                                    CommandParameter="All"
                                    Classes.Active="{Binding IsAllLevelSelected}">
                                <Grid ColumnDefinitions="8,*,Auto">
                                    <Rectangle Width="8"
                                               Height="8"
                                               RadiusX="2"
                                               RadiusY="2"
                                               Fill="{DynamicResource SystemBaseMediumColor}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               Text="All"
                                               FontSize="12"
                                               Margin="8,0,0,0" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding TotalCount}"
                                               FontSize="12"
                                               FontWeight="Medium" />
                                </Grid>
                            </Button>

                            <Button Classes="StatRow"
                                    Command="{Binding SetLevelFilterCommand}"
                                    CommandParameter="Fatal"
                                    Classes.Active="{Binding IsFatalSelected}">
                                <Grid ColumnDefinitions="8,*,Auto">
                                    <Rectangle Width="8" Height="8" RadiusX="2" RadiusY="2"
                                               Fill="{DynamicResource FatalBrush}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="Fatal" FontSize="12" Margin="8,0,0,0" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding FatalCount}"
                                               FontSize="12" FontWeight="Medium"
                                               Foreground="{DynamicResource FatalBrush}" />
                                </Grid>
                            </Button>

                            <Button Classes="StatRow"
                                    Command="{Binding SetLevelFilterCommand}"
                                    CommandParameter="Error"
                                    Classes.Active="{Binding IsErrorSelected}">
                                <Grid ColumnDefinitions="8,*,Auto">
                                    <Rectangle Width="8" Height="8" RadiusX="2" RadiusY="2"
                                               Fill="{DynamicResource ErrorBrush}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="Error" FontSize="12" Margin="8,0,0,0" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding ErrorCount}"
                                               FontSize="12" FontWeight="Medium"
                                               Foreground="{DynamicResource ErrorBrush}" />
                                </Grid>
                            </Button>

                            <Button Classes="StatRow"
                                    Command="{Binding SetLevelFilterCommand}"
                                    CommandParameter="Warning"
                                    Classes.Active="{Binding IsWarningSelected}">
                                <Grid ColumnDefinitions="8,*,Auto">
                                    <Rectangle Width="8" Height="8" RadiusX="2" RadiusY="2"
                                               Fill="{DynamicResource WarningBrush}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="Warning" FontSize="12" Margin="8,0,0,0" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding WarningCount}"
                                               FontSize="12" FontWeight="Medium"
                                               Foreground="{DynamicResource WarningBrush}" />
                                </Grid>
                            </Button>

                            <Button Classes="StatRow"
                                    Command="{Binding SetLevelFilterCommand}"
                                    CommandParameter="Information"
                                    Classes.Active="{Binding IsInformationSelected}">
                                <Grid ColumnDefinitions="8,*,Auto">
                                    <Rectangle Width="8" Height="8" RadiusX="2" RadiusY="2"
                                               Fill="{DynamicResource InformationBrush}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="Information" FontSize="12" Margin="8,0,0,0" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding InformationCount}"
                                               FontSize="12" FontWeight="Medium"
                                               Foreground="{DynamicResource InformationBrush}" />
                                </Grid>
                            </Button>

                            <Button Classes="StatRow"
                                    Command="{Binding SetLevelFilterCommand}"
                                    CommandParameter="Debug"
                                    Classes.Active="{Binding IsDebugSelected}">
                                <Grid ColumnDefinitions="8,*,Auto">
                                    <Rectangle Width="8" Height="8" RadiusX="2" RadiusY="2"
                                               Fill="{DynamicResource DebugBrush}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="Debug" FontSize="12" Margin="8,0,0,0" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding DebugCount}"
                                               FontSize="12" FontWeight="Medium"
                                               Foreground="{DynamicResource DebugBrush}" />
                                </Grid>
                            </Button>

                            <Button Classes="StatRow"
                                    Command="{Binding SetLevelFilterCommand}"
                                    CommandParameter="Verbose"
                                    Classes.Active="{Binding IsVerboseSelected}">
                                <Grid ColumnDefinitions="8,*,Auto">
                                    <Rectangle Width="8" Height="8" RadiusX="2" RadiusY="2"
                                               Fill="{DynamicResource VerboseBrush}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="Verbose" FontSize="12" Margin="8,0,0,0" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding VerboseCount}"
                                               FontSize="12" FontWeight="Medium"
                                               Foreground="{DynamicResource VerboseBrush}" />
                                </Grid>
                            </Button>
                        </StackPanel>
                        </Border>

                        <Separator Margin="0" />

                        <!-- Time chips -->
                        <Border Padding="14,12,14,10">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="SideLabel"
                                       Text="TIME RANGE" />
                            <WrapPanel Orientation="Horizontal">
                                <WrapPanel.Styles>
                                    <Style Selector="Button.TimeChip">
                                        <Setter Property="Margin" Value="0,0,4,4" />
                                    </Style>
                                </WrapPanel.Styles>
                                <Button Classes="TimeChip" Content="1h"
                                        Command="{Binding SetTimeRangeCommand}" CommandParameter="1h"
                                        Classes.Active="{Binding Is1hSelected}" />
                                <Button Classes="TimeChip" Content="4h"
                                        Command="{Binding SetTimeRangeCommand}" CommandParameter="4h"
                                        Classes.Active="{Binding Is4hSelected}" />
                                <Button Classes="TimeChip" Content="12h"
                                        Command="{Binding SetTimeRangeCommand}" CommandParameter="12h"
                                        Classes.Active="{Binding Is12hSelected}" />
                                <Button Classes="TimeChip" Content="1d"
                                        Command="{Binding SetTimeRangeCommand}" CommandParameter="1d"
                                        Classes.Active="{Binding Is1dSelected}" />
                                <Button Classes="TimeChip" Content="7d"
                                        Command="{Binding SetTimeRangeCommand}" CommandParameter="7d"
                                        Classes.Active="{Binding Is7dSelected}" />
                                <Button Classes="TimeChip" Content="1mon"
                                        Command="{Binding SetTimeRangeCommand}" CommandParameter="1mon"
                                        Classes.Active="{Binding Is1monSelected}" />
                                <Button Classes="TimeChip" Content="All"
                                        Command="{Binding SetTimeRangeCommand}" CommandParameter="All"
                                        Classes.Active="{Binding IsAllTimeSelected}" />
                            </WrapPanel>
                        </StackPanel>
                        </Border>

                        <Separator Margin="0" />

                        <!-- Search -->
                        <Border Padding="14,12,14,10">
                        <StackPanel>
                            <TextBlock Classes="SideLabel" Text="SEARCH" />
                            <TextBox Text="{Binding SearchText}"
                                     Watermark="message / exception / props..."
                                     FontSize="11"
                                     FontFamily="Cascadia Code,Consolas,Monospace" />
                        </StackPanel>
                        </Border>

                        <Separator Margin="0" />

                        <!-- Date range -->
                        <Border Padding="14,12,14,12">
                        <StackPanel Spacing="8">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Classes="SideLabel" Text="DATE RANGE" />
                                <Button Grid.Column="1"
                                        Content="✕ clear"
                                        FontSize="10"
                                        Padding="4,1"
                                        Command="{Binding ClearDateRangeCommand}"
                                        IsVisible="{Binding !IsTimeRangeEnabled}" />
                            </Grid>

                            <StackPanel Spacing="4">
                                <TextBlock Text="From" FontSize="10" Opacity="0.45" />
                                <CalendarDatePicker SelectedDate="{Binding StartDate}"
                                                    Watermark="start date"
                                                    FontSize="11" />
                                <TimePicker SelectedTime="{Binding StartTime}"
                                            FontSize="11" />
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Text="To" FontSize="10" Opacity="0.45" />
                                <CalendarDatePicker SelectedDate="{Binding EndDate}"
                                                    Watermark="end date"
                                                    FontSize="11" />
                                <TimePicker SelectedTime="{Binding EndTime}"
                                            FontSize="11" />
                            </StackPanel>
                        </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ─────────────────────────────────────────
                 MAIN: Tabs + DataGrid
            ───────────────────────────────────────── -->
            <Grid Grid.Column="1"
                  RowDefinitions="Auto,*">

                <TabControl Grid.Row="0"
                            Grid.RowSpan="2"
                            Padding="0"
                            TabStripPlacement="Top">

                    <!-- Tab strip custom padding -->
                    <TabControl.Styles>
                        <Style Selector="TabItem">
                            <Setter Property="FontSize" Value="12" />
                            <Setter Property="Padding" Value="14,10" />
                        </Style>
                    </TabControl.Styles>

                    <!-- ── Tab: All logs ── -->
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="All logs" />
                                <Border Background="{DynamicResource InformationBrush}"
                                        CornerRadius="8" Padding="5,1">
                                    <TextBlock Text="{Binding TotalCount}"
                                               FontSize="10"
                                               Foreground="White" />
                                </Border>
                            </StackPanel>
                        </TabItem.Header>

                        <DataGrid ItemsSource="{Binding FilteredLogs}"
                                  SelectedItem="{Binding SelectedLog}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  CanUserResizeColumns="True"
                                  CanUserSortColumns="True">

                            <DataGrid.Styles>
                                <Style Selector="DataGridRow:selected /template/ Rectangle#BackgroundRectangle">
                                    <Setter Property="Fill" Value="{DynamicResource SystemListMediumColor}" />
                                </Style>
                            </DataGrid.Styles>

                            <DataGrid.Columns>

                                <!-- Timestamp -->
                                <DataGridTextColumn Header="Timestamp"
                                                    Width="170"
                                                    FontFamily="Cascadia Code,Consolas,Monospace"
                                                    FontSize="11"
                                                    Binding="{Binding Timestamp, StringFormat=\{0:MM-dd HH:mm:ss.fff\}}" />

                                <!-- Level (template col with badge) -->
                                <DataGridTemplateColumn Header="Level"
                                                        Width="100"
                                                        CanUserSort="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate x:DataType="models:LogEntry">
                                            <Border Classes="LevelBadge"
                                                    Background="{Binding Level, Converter={StaticResource LogLevelToBackgroundConverter}}"
                                                    HorizontalAlignment="Left"
                                                    Margin="4,0">
                                                <TextBlock Text="{Binding Level}"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           FontFamily="Cascadia Code,Consolas,Monospace"
                                                           Foreground="{Binding Level, Converter={StaticResource LogLevelToBrushConverter}}"
                                                           LetterSpacing="0.8" />
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Message -->
                                <DataGridTextColumn Header="Message"
                                                    Width="*"
                                                    FontSize="12"
                                                    Binding="{Binding Message}" />

                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>

                    <!-- ── Tab: Exceptions ── -->
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="Exceptions" />
                                <Border Background="{DynamicResource ErrorBrush}"
                                        CornerRadius="8" Padding="5,1"
                                        IsVisible="{Binding ExceptionCount}">
                                    <TextBlock Text="{Binding ExceptionCount}"
                                               FontSize="10"
                                               Foreground="White" />
                                </Border>
                            </StackPanel>
                        </TabItem.Header>

                        <DataGrid ItemsSource="{Binding ExceptionLogs}"
                                  SelectedItem="{Binding SelectedLog}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  CanUserResizeColumns="True">

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Timestamp"
                                                    Width="170"
                                                    FontFamily="Cascadia Code,Consolas,Monospace"
                                                    FontSize="11"
                                                    Binding="{Binding Timestamp, StringFormat=\{0:MM-dd HH:mm:ss.fff\}}" />

                                <DataGridTemplateColumn Header="Level" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate x:DataType="models:LogEntry">
                                            <Border Classes="LevelBadge"
                                                    Background="{Binding Level, Converter={StaticResource LogLevelToBackgroundConverter}}"
                                                    HorizontalAlignment="Left"
                                                    Margin="4,0">
                                                <TextBlock Text="{Binding Level}"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           FontFamily="Cascadia Code,Consolas,Monospace"
                                                           Foreground="{Binding Level, Converter={StaticResource LogLevelToBrushConverter}}"
                                                           LetterSpacing="0.8" />
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="Message" Width="*"
                                                    FontSize="12"
                                                    Binding="{Binding Message}" />

                                <DataGridTextColumn Header="Exception"
                                                    Width="260"
                                                    FontSize="11"
                                                    FontFamily="Cascadia Code,Consolas,Monospace"
                                                    Binding="{Binding Exception}" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>

                </TabControl>
            </Grid>

            <!-- Splitter -->
            <GridSplitter Grid.Column="2"
                          Width="5"
                          ResizeDirection="Columns"
                          Background="Transparent" />

            <!-- ─────────────────────────────────────────
                 DETAIL PANEL
            ───────────────────────────────────────── -->
            <Border Grid.Column="3"
                    BorderThickness="1,0,0,0"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                    IsVisible="{Binding SelectedLog, Converter={x:Static ObjectConverters.IsNotNull}}">

                <Grid RowDefinitions="Auto,*">

                    <!-- Detail header -->
                    <Border Grid.Row="0"
                            BorderThickness="0,0,0,1"
                            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                            Padding="14,10">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="LOG DETAIL"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       LetterSpacing="1.5"
                                       Opacity="0.5"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="1"
                                    Content="✕"
                                    Command="{Binding ClearSelectionCommand}"
                                    Padding="6,2"
                                    FontSize="11" />
                        </Grid>
                    </Border>

                    <!-- Detail body -->
                    <ScrollViewer Grid.Row="1">
                        <Border Padding="14">
                        <StackPanel Spacing="16">

                            <!-- Timestamp -->
                            <StackPanel Spacing="3">
                                <TextBlock Classes="DetailKey" Text="TIMESTAMP" />
                                <TextBlock Classes="DetailVal Mono"
                                           Text="{Binding SelectedLog.Timestamp,
                                                  StringFormat=\{0:yyyy-MM-dd HH:mm:ss.fff\}}" />
                            </StackPanel>

                            <!-- Level -->
                            <StackPanel Spacing="3">
                                <TextBlock Classes="DetailKey" Text="LEVEL" />
                                <Border Classes="LevelBadge"
                                        HorizontalAlignment="Left"
                                        Background="{Binding SelectedLog.Level,
                                                     Converter={StaticResource LogLevelToBackgroundConverter}}">
                                    <TextBlock Text="{Binding SelectedLog.Level}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               FontFamily="Cascadia Code,Consolas,Monospace"
                                               Foreground="{Binding SelectedLog.Level,
                                                            Converter={StaticResource LogLevelToBrushConverter}}" />
                                </Border>
                            </StackPanel>

                            <!-- Message -->
                            <StackPanel Spacing="3">
                                <TextBlock Classes="DetailKey" Text="MESSAGE" />
                                <TextBlock Classes="DetailVal"
                                           Text="{Binding SelectedLog.Message}" />
                            </StackPanel>

                            <!-- Exception -->
                            <StackPanel Spacing="3"
                                        IsVisible="{Binding SelectedLog.Exception,
                                                    Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <TextBlock Classes="DetailKey" Text="EXCEPTION" />
                                <Border Background="{DynamicResource SystemErrorTextColor}"
                                        Opacity="0.8"
                                        CornerRadius="6"
                                        Padding="10,8"
                                        BorderBrush="{DynamicResource ErrorBrush}"
                                        BorderThickness="2,0,0,0">
                                    <TextBlock Text="{Binding SelectedLog.Exception}"
                                               FontFamily="Cascadia Code,Consolas,Monospace"
                                               FontSize="11"
                                               Foreground="{DynamicResource ErrorBrush}"
                                               TextWrapping="Wrap"
                                               LineHeight="18" />
                                </Border>
                            </StackPanel>

                            <!-- Properties -->
                            <StackPanel Spacing="3"
                                        IsVisible="{Binding HasSelectedProperties}">
                                <TextBlock Classes="DetailKey" Text="PROPERTIES" />

                                <Border CornerRadius="6"
                                        BorderThickness="0.5"
                                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                        Padding="10,8">
                                    <ItemsControl ItemsSource="{Binding SelectedLog.Properties}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid ColumnDefinitions="120,*"
                                                      Margin="0,3">
                                                    <TextBlock Text="{Binding Key}"
                                                               FontSize="11"
                                                               FontWeight="Medium"
                                                               Opacity="0.55"
                                                               TextTrimming="CharacterEllipsis"
                                                               FontFamily="Cascadia Code,Consolas,Monospace" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Value}"
                                                               FontSize="11"
                                                               TextWrapping="Wrap"
                                                               FontFamily="Cascadia Code,Consolas,Monospace" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                            </StackPanel>

                        </StackPanel>
                        </Border>
                    </ScrollViewer>
                </Grid>
            </Border>

        </Grid>
    </Grid>

</Window>
